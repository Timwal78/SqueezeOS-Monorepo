@app.route('/api/market/quotes')
def get_quotes():
    symbols = [s.strip().upper() for s in request.args.get('symbols', '').split(',') if s.strip()]
    with state.lock:
        res = {s: state.quotes[s] for s in symbols if s in state.quotes}

    # Live Tradier fallback — fires when scanner cache is cold (fresh restart / market closed)
    missing = [s for s in symbols if s not in res]
    if missing:
        try:
            import requests as _req
            # Check all possible Tradier key env var names
            _key = (os.environ.get('TRADIER_PRODUCTION_API_KEY') or
                    os.environ.get('TRADIER_API_KEY') or '')
            _live = os.environ.get('TRADIER_LIVE', 'false').lower() == 'true'
            _base = 'https://api.tradier.com/v1' if _live else 'https://sandbox.tradier.com/v1'
            logger.info(f'[QUOTES] Cold cache fallback: key={bool(_key)}, live={_live}, missing={missing}')
            if _key:
                _r = _req.get(f'{_base}/markets/quotes',
                              headers={'Authorization': f'Bearer {_key}', 'Accept': 'application/json'},
                              params={'symbols': ','.join(missing), 'greeks': 'false'}, timeout=8)
                logger.info(f'[QUOTES] Tradier response: {_r.status_code}')
                if _r.status_code == 200:
                    _quotes = _r.json().get('quotes', {}).get('quote', [])
                    if isinstance(_quotes, dict): _quotes = [_quotes]
                    for q in _quotes:
                        sym = q.get('symbol', '')
                        if sym:
                            entry = {
                                'price': q.get('last') or q.get('prevclose') or 0,
                                'change': q.get('change', 0),
                                'changePct': q.get('change_percentage', 0),
                                'volume': q.get('volume', 0),
                                'high': q.get('high', 0),
                                'low': q.get('low', 0),
                                'open': q.get('open', 0),
                                'bid': q.get('bid', 0),
                                'ask': q.get('ask', 0),
                                'source': 'tradier_live'
                            }
                            res[sym] = entry
                            with state.lock:
                                state.quotes[sym] = entry
                            logger.info(f'[QUOTES] Tradier live: {sym} @ {entry["price"]}')
            else:
                logger.warning('[QUOTES] No Tradier key found in environment')
        except Exception as _e:
            logger.warning(f'[QUOTES] Live fallback exception: {_e}')


    if not res:
        # Signal to frontend: data providers attempted but returned nothing
        return jsonify({"status": "success", "data": {}, "error": "NO_DATA"})
    return jsonify({"status": "success", "data": res})


